{
  "name": "iot-nexus-core",
  "version": "1.1.32",
  "description": "Enterprise IoT Device Management Platform",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win --x64 -c.publish.provider=github -c.publish.releaseType=release -p always",
    "build:mac": "npm run build && electron-builder --mac --x64 -c.publish.provider=github -c.publish.releaseType=release -p always",
    "release": "node scripts/release.js"
  },
  "author": "Nexus Team",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@matter/main": "^0.15.6",
    "@matter/nodejs": "^0.15.6",
    "@matter/nodejs-ble": "^0.15.6",
    "@matter/protocol": "^0.15.6",
    "@project-chip/matter.js": "^0.15.6",
    "@serialport/parser-readline": "^13.0.0",
    "@stoprocent/noble": "^2.3.10",
    "adm-zip": "^0.5.16",
    "ajv": "^6.12.6",
    "axios": "^1.13.3",
    "bonjour-service": "^1.3.0",
    "lucide-react": "^0.561.0",
    "mqtt": "^5.10.1",
    "multicast-dns": "^7.2.5",
    "mysql2": "^3.16.1",
    "node-wifi": "^2.0.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "serialport": "^13.0.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@matter/examples": "^0.15.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "io.nexus.iot.core",
    "productName": "IoT Nexus Core",
    "directories": {
      "output": "release"
    },
    "protocols": [
      {
        "name": "IoT Nexus Protocol",
        "schemes": [
          "meross-qa"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "matter-commissioner.cjs",
      "matter-controller.cjs",
      "discovery-service.cjs",
      "package.json",
      "services/**/*"
    ],
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
