{
  "name": "iot-nexus-core",
  "version": "1.0.0",
  "description": "Enterprise IoT Device Management Platform",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "start": "electron .",
    "package": "npm run build && electron-builder"
  },
  "author": "Nexus Team",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.34.0",
    "lucide-react": "^0.561.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "io.nexus.iot.core",
    "productName": "IoT Nexus Core",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}